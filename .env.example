# --- PROD / CLOUD CONFIGURATION ---

# MongoDB Atlas URI (Srv String)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/chatbot_db?retryWrites=true&w=majority
DATABASE_NAME=chatbot_db

# Redis Cloud URL
REDIS_URL=redis://:<password>@redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com:12345

# Ollama Configuration (if using local/external Ollama)
OLLAMA_HOST=http://localhost:11434

# --- API CONFIG ---
PORT=8000
HOST=0.0.0.0
